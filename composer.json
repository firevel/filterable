{
    "name": "firevel/filterable",
    "description": "A simple trait for Laravel Eloquent models that allows you to easily filter your queries.",
    "keywords": ["laravel", "firevel", "trait", "filterable", "filters"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Michael Slowik",
            "email": "michael.slowik@firevel.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Firevel\\Filterable\\": "src/"
        }
    },
    "minimum-stability": "dev"
}